<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="arm">

        <!-- Base de montaje -->
        <link name="arm_mount_link"/>

        <joint name="base_to_arm" type="fixed">
            <parent link="base_link"/>
            <child link="arm_mount_link"/>
            <origin xyz="0.1 0 0.25" rpy="0 0 0"/>
        </joint>

        <!-- ARM BASE -->
        <link name="arm_base_link_fixed"/>

        <joint name="mount_to_arm_base" type="fixed">
            <parent link="arm_mount_link"/>
            <child link="arm_base_link_fixed"/>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
        </joint>

        <!-- LINK 1 -->
        <link name="link_1"/>

        <joint name="joint_1" type="revolute">
            <parent link="arm_base_link_fixed"/>
            <child link="link_1"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-3.1416" upper="3.1416" effort="20.0" velocity="2.0"/>
        </joint>

        <!-- LINK 2 -->
        <link name="link_2"/>

        <joint name="joint_2" type="revolute">
            <parent link="link_1"/>
            <child link="link_2"/>
            <origin xyz="0 0 0.10" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
            <limit lower="-1.5708" upper="1.5708" effort="30.0" velocity="1.5"/>
        </joint>

        <!-- LINK 3 -->
        <link name="link_3"/>

        <joint name="joint_3" type="revolute">
            <parent link="link_2"/>
            <child link="link_3"/>
            <origin xyz="0.40 0 0" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
            <limit lower="-2.0944" upper="2.0944" effort="20.0" velocity="2.0"/>
        </joint>

        <!-- LINK 4 -->
        <link name="link_4"/>

        <joint name="joint_4" type="revolute">
            <parent link="link_3"/>
            <child link="link_4"/>
            <origin xyz="0.40 0 0" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
            <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="2.5"/>
        </joint>

        <!-- TOOL -->
        <link name="tool0"/>

        <joint name="joint_5" type="revolute">
            <parent link="link_4"/>
            <child link="tool0"/>
            <origin xyz="0.05 0 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-3.1416" upper="3.1416" effort="10.0" velocity="3.0"/>
        </joint>

        <!-- TCP -->
        <link name="tcp"/>

        <joint name="tool0_to_tcp" type="fixed">
            <parent link="tool0"/>
            <child link="tcp"/>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
        </joint>

    </xacro:macro>

</robot>