<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot_amr_manipulator">

    <xacro:property name="base_mass"   value="25.0"/>
    <xacro:property name="base_length" value="0.60"/>
    <xacro:property name="base_width"  value="0.45"/>
    <xacro:property name="base_height" value="0.25"/>
    
    <xacro:property name="wheel_mass"  value="2.0"/>
    <xacro:property name="wheel_radius" value="0.08"/>
    <xacro:property name="wheel_width"  value="0.05"/>
    <xacro:property name="wheel_ygap"   value="0.02"/>
    <xacro:property name="wheel_separation" value="0.36"/> <xacro:property name="caster_radius" value="0.04"/>
    <xacro:property name="caster_mass"   value="1.0"/>
    
    <xacro:property name="arm_mass_p1" value="1.5"/> <xacro:property name="L1" value="0.10"/> <xacro:property name="L2" value="0.40"/> <xacro:property name="L3" value="0.40"/> <xacro:property name="Wrist" value="0.05"/> <xacro:property name="TCP_ext" value="0.15"/> <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    <material name="light_grey"><color rgba="0.7 0.7 0.7 1.0"/></material>
    <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>
    <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>

    <xacro:macro name="box_inertial" params="mass x y z *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}"/>
            <inertia ixx="${(1.0/12.0) * mass * (y*y + z*z)}" ixy="0.0" ixz="0.0"
                     iyy="${(1.0/12.0) * mass * (x*x + z*z)}" iyz="0.0"
                     izz="${(1.0/12.0) * mass * (x*x + y*y)}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="cylinder_inertial" params="mass r h *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}"/>
            <inertia ixx="${(1.0/12.0) * mass * (3*r*r + h*h)}" ixy="0.0" ixz="0.0"
                     iyy="${(1.0/12.0) * mass * (3*r*r + h*h)}" iyz="0.0"
                     izz="${(1.0/2.0) * mass * r*r}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="sphere_inertial" params="mass r *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}"/>
            <inertia ixx="${(2.0/5.0) * mass * r*r}" ixy="0.0" ixz="0.0"
                     iyy="${(2.0/5.0) * mass * r*r}" iyz="0.0"
                     izz="${(2.0/5.0) * mass * r*r}"/>
        </inertial>
    </xacro:macro>

    <link name="base_footprint"/>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
        </collision>
        <xacro:box_inertial mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}">
            <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
        </xacro:box_inertial>
    </link>

    <xacro:macro name="wheel" params="prefix y_reflect">
        <link name="${prefix}_wheel_link">
            <visual>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
            </collision>
            <xacro:cylinder_inertial mass="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}">
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            </xacro:cylinder_inertial>
        </link>

        <joint name="${prefix}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_wheel_link"/>
            <origin xyz="0 ${y_reflect * wheel_separation / 2.0} 0" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
        </joint>
    </xacro:macro>

    <xacro:wheel prefix="left"  y_reflect="1"/>
    <xacro:wheel prefix="right" y_reflect="-1"/>

    <xacro:macro name="caster" params="prefix x_offset">
        <link name="${prefix}_caster_link">
            <visual>
                <geometry><sphere radius="${caster_radius}"/></geometry>
                <material name="black"/>
            </visual>
            <collision>
                <geometry><sphere radius="${caster_radius}"/></geometry>
            </collision>
            <xacro:sphere_inertial mass="${caster_mass}" r="${caster_radius}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:sphere_inertial>
        </link>

        <joint name="${prefix}_caster_joint" type="fixed">
            <parent link="base_link"/>
            <child link="${prefix}_caster_link"/>
            <origin xyz="${x_offset} 0 ${caster_radius - wheel_radius}" rpy="0 0 0"/>
        </joint>
    </xacro:macro>

    <xacro:caster prefix="front" x_offset="0.22"/>
    <xacro:caster prefix="rear"  x_offset="-0.22"/>

    <link name="lidar_link">
        <visual>
            <geometry><cylinder radius="0.05" length="0.04"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry><cylinder radius="0.05" length="0.04"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="0.3" r="0.05" h="0.04">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0.20 0 0.195" rpy="0 0 0"/>
    </joint>

    <link name="camera_link">
        <visual>
            <geometry><box size="0.03 0.08 0.03"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry><box size="0.03 0.08 0.03"/></geometry>
        </collision>
        <xacro:box_inertial mass="0.15" x="0.03" y="0.08" z="0.03">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:box_inertial>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <origin xyz="0.29 0 ${base_height - 0.015}" rpy="0 0 0"/>
    </joint>

    <link name="imu_link">
        <visual>
            <geometry><box size="0.02 0.02 0.01"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry><box size="0.02 0.02 0.01"/></geometry>
        </collision>
        <xacro:box_inertial mass="0.05" x="0.02" y="0.02" z="0.01">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:box_inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
    </joint>

    <link name="arm_mount_link">
        <visual>
            <geometry><cylinder radius="0.08" length="0.02"/></geometry>
            <material name="light_grey"/>
        </visual>
        <collision>
            <geometry><cylinder radius="0.08" length="0.02"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="0.5" r="0.08" h="0.02">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="arm_mount_joint" type="fixed">
        <parent link="base_link"/>
        <child link="arm_mount_link"/>
        <origin xyz="0.0 0 ${base_height}" rpy="0 0 0"/>
    </joint>

    <link name="arm_base_link">
        <visual>
            <geometry><cylinder radius="0.06" length="0.04"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry><cylinder radius="0.06" length="0.04"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="0.8" r="0.06" h="0.04">
            <origin xyz="0 0 0.02" rpy="0 0 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="arm_root_joint" type="fixed">
        <parent link="arm_mount_link"/>
        <child link="arm_base_link"/>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </joint>

    <link name="link_1">
        <visual>
            <origin xyz="0 0 ${L1/2.0}" rpy="0 0 0"/>
            <geometry><cylinder radius="0.05" length="${L1}"/></geometry>
            <material name="light_grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 ${L1/2.0}" rpy="0 0 0"/>
            <geometry><cylinder radius="0.05" length="${L1}"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="${arm_mass_p1}" r="0.05" h="${L1}">
            <origin xyz="0 0 ${L1/2.0}" rpy="0 0 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="joint_1" type="revolute">
        <parent link="arm_base_link"/>
        <child link="link_1"/>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <axis xyz="0 0 1"/> <limit lower="-3.1416" upper="3.1416" effort="20.0" velocity="2.0"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>

    <link name="link_2">
        <visual>
            <origin xyz="${L2/2.0} 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.04" length="${L2}"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="${L2/2.0} 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.04" length="${L2}"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="${arm_mass_p1}" r="0.04" h="${L2}">
            <origin xyz="${L2/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="joint_2" type="revolute">
        <parent link="link_1"/>
        <child link="link_2"/>
        <origin xyz="0 0 ${L1}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/> <limit lower="-1.5708" upper="1.5708" effort="30.0" velocity="1.5"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>

    <link name="link_3">
        <visual>
            <origin xyz="${L3/2.0} 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.035" length="${L3}"/></geometry>
            <material name="light_grey"/>
        </visual>
        <collision>
            <origin xyz="${L3/2.0} 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.035" length="${L3}"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="${arm_mass_p1}" r="0.035" h="${L3}">
            <origin xyz="${L3/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="joint_3" type="revolute">
        <parent link="link_2"/>
        <child link="link_3"/>
        <origin xyz="${L2} 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/> <limit lower="-2.0944" upper="2.0944" effort="20.0" velocity="2.0"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>

    <link name="link_4">
        <visual>
            <origin xyz="${Wrist/2.0} 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.025" length="${Wrist}"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="${Wrist/2.0} 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.025" length="${Wrist}"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="0.5" r="0.025" h="${Wrist}">
            <origin xyz="${Wrist/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="joint_4" type="revolute">
        <parent link="link_3"/>
        <child link="link_4"/>
        <origin xyz="${L3} 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/> <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="2.5"/>
        <dynamics damping="0.3" friction="0.1"/>
    </joint>

    <link name="tool0">
        <visual>
            <origin xyz="0.01 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.03" length="0.02"/></geometry>
            <material name="dark_grey"/>
        </visual>
        <collision>
            <origin xyz="0.01 0 0" rpy="0 ${pi/2} 0"/>
            <geometry><cylinder radius="0.03" length="0.02"/></geometry>
        </collision>
        <xacro:cylinder_inertial mass="0.3" r="0.03" h="0.02">
            <origin xyz="0.01 0 0" rpy="0 ${pi/2} 0"/>
        </xacro:cylinder_inertial>
    </link>

    <joint name="joint_5" type="revolute">
        <parent link="link_4"/>
        <child link="tool0"/>
        <origin xyz="${Wrist} 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/> <limit lower="-3.1416" upper="3.1416" effort="10.0" velocity="3.0"/>
        <dynamics damping="0.3" friction="0.1"/>
    </joint>

    <link name="tcp">
        <visual>
            <origin xyz="0.075 0 0" rpy="0 0 0"/>
            <geometry><box size="${TCP_ext} 0.06 0.01"/></geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0.075 0 0" rpy="0 0 0"/>
            <geometry><box size="${TCP_ext} 0.06 0.01"/></geometry>
        </collision>
        <xacro:box_inertial mass="0.2" x="${TCP_ext}" y="0.06" z="0.01">
            <origin xyz="0.075 0 0" rpy="0 0 0"/>
        </xacro:box_inertial>
    </link>

    <joint name="tool0_to_tcp" type="fixed">
        <parent link="tool0"/>
        <child link="tcp"/>
        <origin xyz="${TCP_ext} 0 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="base_link">
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    <gazebo reference="left_wheel_link">
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <material>Gazebo/Black</material>
    </gazebo>
    <gazebo reference="right_wheel_link">
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <material>Gazebo/Black</material>
    </gazebo>
    <gazebo reference="front_caster_link">
        <mu1>0.01</mu1>
        <mu2>0.01</mu2>
        <material>Gazebo/Black</material>
    </gazebo>
    <gazebo reference="rear_caster_link">
        <mu1>0.01</mu1>
        <mu2>0.01</mu2>
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            <wheel_separation>${wheel_separation}</wheel_separation>
            <wheel_radius>${wheel_radius}</wheel_radius>
            <max_linear_acceleration>1.5</max_linear_acceleration>
            <odom_publish_frequency>50</odom_publish_frequency>
            <topic>/cmd_vel</topic>
            <odom_topic>/odom</odom_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
        </plugin>
        
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <topic>/joint_states</topic>
            <joint_name>left_wheel_joint</joint_name>
            <joint_name>right_wheel_joint</joint_name>
            <joint_name>joint_1</joint_name>
            <joint_name>joint_2</joint_name>
            <joint_name>joint_3</joint_name>
            <joint_name>joint_4</joint_name>
            <joint_name>joint_5</joint_name>
        </plugin>
    </gazebo>

    <ros2_control name="ArmControlSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        <joint name="joint_1">
            <command_interface name="position">
                <param name="min">-3.1416</param>
                <param name="max">3.1416</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_2">
            <command_interface name="position">
                <param name="min">-1.5708</param>
                <param name="max">1.5708</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_3">
            <command_interface name="position">
                <param name="min">-2.0944</param>
                <param name="max">2.0944</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_4">
            <command_interface name="position">
                <param name="min">-1.5708</param>
                <param name="max">1.5708</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_5">
            <command_interface name="position">
                <param name="min">-3.1416</param>
                <param name="max">3.1416</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters></parameters>
        </plugin>
    </gazebo>

</robot>