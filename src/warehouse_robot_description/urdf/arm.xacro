<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Properties -->
  <xacro:property name="arm_radius" value="0.04" />
  <xacro:property name="arm_base_h" value="0.05" />
  <xacro:property name="link1_h" value="0.05" />
  <xacro:property name="link2_l" value="0.4" />
  <xacro:property name="link3_l" value="0.3" />
  <xacro:property name="link4_l" value="0.1" />
  
  <material name="arm_gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>

  <material name="arm_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- Macro for cylindrical inertial -->
  <xacro:macro name="cylinder_inertial" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(3*radius*radius + length*length)/12}" ixy="0" ixz="0" 
               iyy="${mass*(3*radius*radius + length*length)/12}" iyz="0" 
               izz="${mass*radius*radius/2}"/>
    </inertial>
  </xacro:macro>

  <!-- Arm Base -->
  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 ${arm_base_h/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*1.5}" length="${arm_base_h}"/>
      </geometry>
      <material name="arm_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_base_h/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*1.5}" length="${arm_base_h}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.5" radius="${arm_radius*1.5}" length="${arm_base_h}"/>
  </link>

  <joint name="arm_mount_to_base" type="fixed">
    <parent link="arm_mount_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>

  <!-- Link 1 (Yaw) -->
  <link name="link_1">
    <visual>
      <origin xyz="0 0 ${link1_h/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${link1_h}"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link1_h/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${link1_h}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.4" radius="${arm_radius}" length="${link1_h}"/>
  </link>

  <joint name="joint1_yaw" type="revolute">
    <parent link="arm_base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 ${arm_base_h}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1415" upper="3.1415" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 2 (Shoulder Pitch) -->
  <link name="link_2">
    <visual>
      <origin xyz="0 0 ${link2_l/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${link2_l}"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link2_l/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${link2_l}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="1.0" radius="${arm_radius}" length="${link2_l}"/>
  </link>

  <joint name="joint2_pitch" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 ${link1_h}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 3 (Elbow Pitch) -->
  <link name="link_3">
    <visual>
      <origin xyz="0 0 ${link3_l/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*0.8}" length="${link3_l}"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link3_l/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*0.8}" length="${link3_l}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.8" radius="${arm_radius*0.8}" length="${link3_l}"/>
  </link>

  <joint name="joint3_pitch" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 ${link2_l}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 4 (Wrist Pitch) -->
  <link name="link_4">
    <visual>
      <origin xyz="0 0 ${link4_l/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*0.6}" length="${link4_l}"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link4_l/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*0.6}" length="${link4_l}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.3" radius="${arm_radius*0.6}" length="${link4_l}"/>
  </link>

  <joint name="joint4_pitch" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 ${link3_l}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="50" velocity="1.0"/>
  </joint>

  <!-- Wrist Roll Link -->
  <link name="wrist_roll_link">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*0.7}" length="0.02"/>
      </geometry>
      <material name="arm_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*0.7}" length="0.02"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.1" radius="${arm_radius*0.7}" length="0.02"/>
  </link>

  <joint name="joint5_roll" type="revolute">
    <parent link="link_4"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0 0 ${link4_l}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1415" upper="3.1415" effort="50" velocity="1.0"/>
  </joint>

  <!-- Gazebo colors -->
  <gazebo reference="arm_base_link">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="link_1">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="link_2">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="link_3">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="link_4">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="wrist_roll_link">
    <material>Gazebo/Black</material>
  </gazebo>

</robot>
