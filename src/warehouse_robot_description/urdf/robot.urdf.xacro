<?xml version="1.0"?>
<robot name="warehouse_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find warehouse_robot_description)/urdf/base.xacro" />
  <xacro:include filename="$(find warehouse_robot_description)/urdf/wheels.xacro" />
  <xacro:include filename="$(find warehouse_robot_description)/urdf/sensors.xacro" />
  <xacro:include filename="$(find warehouse_robot_description)/urdf/arm_mount.xacro" />

</robot>
