<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Gripper Base -->
  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.04 0.04"/>
      </geometry>
      <material name="gripper_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- Left Finger -->
  <link name="left_finger">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.03 0.06"/>
      </geometry>
      <material name="gripper_gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.03 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="left_finger"/>
    <origin xyz="-0.11 0 0.04" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.08"/>
    <dynamics damping="6.0" friction="2.0"/>
  </joint>

  <!-- Right Finger -->
  <link name="right_finger">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.03 0.06"/>
      </geometry>
      <material name="gripper_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.03 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="right_finger"/>
    <origin xyz="0.11 0 0.04" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.08"/>
    <dynamics damping="6.0" friction="2.0"/>
  </joint>

  <!-- Gazebo Colors -->
  <gazebo reference="gripper_base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="left_finger">
    <material>Gazebo/Grey</material>
    <mu1>12.0</mu1>
    <mu2>12.0</mu2>
    <kp>50000.0</kp>
    <kd>15.0</kd>
    <minDepth>0.0005</minDepth>
  </gazebo>
  <gazebo reference="right_finger">
    <material>Gazebo/Grey</material>
    <mu1>12.0</mu1>
    <mu2>12.0</mu2>
    <kp>50000.0</kp>
    <kd>15.0</kd>
    <minDepth>0.0005</minDepth>
  </gazebo>

</robot>
